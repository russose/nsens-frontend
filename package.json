{
  "name": "frontend",
  "version": "1.0.0",
  "description": "frontend for Dimension5",
  "author": "Salvatore Russo",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "next",
    "build": "next build",
    "start": "next start",
    "sitemap": "next-sitemap",
    "export": "next build && next-sitemap && next export -o frontend-static && cp .htaccess frontend-static/ && tar c -Ipbzip2 -f frontend-static.tar.bz2 frontend-static/ && rm -rf frontend-static/",
    "serve": "next export -o frontend-static && serve frontend-static -l 3000",
    "depgraph": "depcruise -x node_module -v -T dot -- 'pages/**/index.tsx' | dot -T svg | depcruise-wrap-stream-in-html > dependency-graph.html",
    "test": "echo \"Error: no test specified\" && exit 1",
    "bundle-wizard": "bundle-wizard http://192.168.1.51:3000/fr/mobile/ --interact",
    "lint": "next lint"
  },
  "keywords": [],
  "dependencies": {
    "axios": "^1.3.5",
    "d3-force": "^3.0.0",
    "gestalt": "^117.2.4",
    "mobx": "^6.9.0",
    "mobx-react-lite": "^4.0.3",
    "next": "^13.3.0",
    "next-pwa": "^5.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-force-graph-2d": "^1.24.1",
    "react-force-graph-3d": "^1.22.1",
    "react-intersection-observer": "^9.4.3",
    "three": "^0.154.0",
    "xml2js": "^0.6.0"
  },
  "devDependencies": {
    "@bubblewrap/cli": "^1.20.0",
    "@next/bundle-analyzer": "^13.3.0",
    "@types/d3-force": "^3.0.4",
    "@types/node": "^20.2.1",
    "@types/puppeteer": "^7.0.4",
    "@types/react": "^18.0.33",
    "@types/react-dom": "^18.0.11",
    "@types/three": "^0.154.0",
    "dependency-cruiser": "^13.0.1",
    "eslint": "^8.37.0",
    "eslint-config-next": "^13.3.0",
    "next-sitemap": "^4.1.3",
    "puppeteer-core": "^20.2.1",
    "serve": "^14.2.0",
    "typescript": "^5.0.4"
  },
  "comments": {
    "next-transpile-modules": "used for amCharts or any lib that needs next.config.js",
    "@types/lz-string": "^1.3.34",
    "lz-string": "^1.4.4",
    "react-share": "^4.4.0",
    "react-waypoint": "^10.3.0",
    "start-pm2": "pm2 start \"next start\" --name Front",
    "docker_old": "next build && pm2-runtime \"next start\" --name Front",
    "docker": "next build && next start",
    "dev-pm2": "pm2 start next --name Front"
  }
}