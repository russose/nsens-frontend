{
  "name": "frontend",
  "version": "1.0.0",
  "description": "frontend for Dimension5",
  "author": "Salvatore Russo <salvatore.russo@laposte.net>",
  "license": "UNLICENSED",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "next",
    "dev-pm2": "pm2 start next --name Front",
    "build": "next build",
    "start": "next start",
    "export": "next build && next-sitemap && next export -o frontend-static && cp .htaccess frontend-static/ && tar c -Ipbzip2 -f frontend-static.tar.bz2 frontend-static/ && rm -rf frontend-static/",
    "serve": "next export -o frontend-static && serve frontend-static -l 3000",
    "depgraph": "depcruise -x node_module -v -T dot -- 'pages/**/index.tsx' | dot -T svg | depcruise-wrap-stream-in-html > dependency-graph.html",
    "start-pm2": "pm2 start \"next start\" --name Front",
    "docker_old": "next build && pm2-runtime \"next start\" --name Front",
    "docker": "next build && next start",
    "test": "echo \"Error: no test specified\" && exit 1",
    "bundle-wizard": "bundle-wizard http://192.168.1.51:3000/fr/mobile/ --interact",
    "lint": "next lint"
  },
  "keywords": [],
  "dependencies": {
    "@fseehawer/react-circular-slider": "^2.5.9",
    "@visx/group": "^2.10.0",
    "@visx/network": "^2.10.0",
    "@visx/shape": "^2.11.1",
    "@visx/text": "^2.10.0",
    "@visx/zoom": "^2.10.0",
    "axios": "^0.27.2",
    "d3-force": "^3.0.0",
    "gestalt": "^71.0.12",
    "mobx": "^6.6.1",
    "mobx-react-lite": "^3.4.0",
    "next": "^12.2.0",
    "next-pwa": "^5.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-intersection-observer": "^9.4.0"
  },
  "devDependencies": {
    "@bubblewrap/cli": "^1.18.0",
    "@next/bundle-analyzer": "^12.2.4",
    "@types/d3-force": "^3.0.3",
    "@types/gestalt": "^62.0.0",
    "@types/node": "^18.0.3",
    "@types/puppeteer": "^5.4.6",
    "@types/react": "^18.0.15",
    "@types/react-dom": "^18.0.6",
    "@types/sharp": "^0.30.5",
    "bundle-wizard": "^1.6.1",
    "dependency-cruiser": "^11.11.0",
    "eslint": "^8.21.0",
    "eslint-config-next": "^12.2.4",
    "next-sitemap": "^3.1.10",
    "puppeteer-core": "^17.1.1",
    "serve": "^14.0.1",
    "sharp": "^0.31.0",
    "typescript": "^4.7.4"
  },
  "comments": {
    "next-transpile-modules": "used for amCharts or any lib that needs next.config.js",
    "@types/lz-string": "^1.3.34",
    "lz-string": "^1.4.4",
    "react-share": "^4.4.0",
    "react-waypoint": "^10.3.0"
  }
}
