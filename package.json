{
  "name": "frontend",
  "version": "1.0.0",
  "description": "frontend for Dimension5",
  "author": "Salvatore Russo <salvatore.russo@laposte.net>",
  "license": "UNLICENSED",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "next",
    "dev-pm2": "pm2 start next --name Front",
    "build": "next build",
    "start": "next start",
    "export": "rm -rf frontend-static/ && next build && next-sitemap && next export -o frontend-static && cp .htaccess frontend-static/ && tar c -Ipbzip2 -f frontend-static.tar.bz2 frontend-static/ ",
    "serve": "serve frontend-static -l 3000",
    "depgraph": "depcruise -x node_module -v -T dot -- 'pages/**/Home.tsx' | dot -T svg | depcruise-wrap-stream-in-html > dependency-graph.html",
    "start-pm2": "pm2 start \"next start\" --name Front",
    "docker_old": "next build && pm2-runtime \"next start\" --name Front",
    "docker": "next build && next start",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "dependencies": {
    "@artsy/fresnel": "^1.9.0",
    "@types/lz-string": "^1.3.34",
    "@visx/group": "^1.7.0",
    "@visx/network": "^1.7.0",
    "@visx/shape": "^1.7.0",
    "@visx/text": "^1.7.0",
    "@visx/zoom": "^1.7.0",
    "axios": "^0.21.1",
    "d3-force": "^3.0.0",
    "gestalt": "^29.6.4",
    "lz-string": "^1.4.4",
    "mobx": "^6.1.8",
    "mobx-react-lite": "^3.2.0",
    "next": "^10.0.8",
    "next-pwa": "^5.2.23",
    "react": "^16.0.0",
    "react-dom": "^16.0.0",
    "react-waypoint": "^10.1.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^11.0.1",
    "@types/d3-force": "^3.0.3",
    "@types/gestalt": "^29.1.0",
    "@types/node": "^16.4.10",
    "@types/react": "^17.0.3",
    "dependency-cruiser": "^10.0.2",
    "next-sitemap": "^1.6.20",
    "serve": "^12.0.0",
    "typescript": "^4.2.3"
  },
  "comments": {
    "next-transpile-modules": "used for amCharts or any lib that needs next.config.js"
  }
}
