{
  "name": "frontend",
  "version": "1.0.0",
  "description": "frontend for Dimension5",
  "author": "Salvatore Russo <salvatore.russo@laposte.net>",
  "license": "UNLICENSED",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "next",
    "dev-pm2": "pm2 start next --name Front",
    "build": "next build",
    "start": "next start",
    "export": "rm -rf frontend-static/ && next build && next-sitemap && next export -o frontend-static && cp .htaccess frontend-static/ && tar c -Ipbzip2 -f frontend-static.tar.bz2 frontend-static/ ",
    "serve": "serve frontend-static -l 3000",
    "depgraph": "depcruise -x node_module -v -T dot -- 'pages/**/Home.tsx' | dot -T svg | depcruise-wrap-stream-in-html > dependency-graph.html",
    "start-pm2": "pm2 start \"next start\" --name Front",
    "docker_old": "next build && pm2-runtime \"next start\" --name Front",
    "docker": "next build && next start",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "dependencies": {
    "@artsy/fresnel": "^3.2.1",
    "@fseehawer/react-circular-slider": "^2.3.9",
    "@visx/group": "^2.1.0",
    "@visx/network": "^2.1.2",
    "@visx/shape": "^2.4.0",
    "@visx/text": "^2.3.0",
    "@visx/zoom": "^2.6.1",
    "axios": "^0.26.0",
    "d3-force": "^3.0.0",
    "gestalt": "^45.5.5",
    "mobx": "^6.3.13",
    "mobx-react-lite": "^3.2.3",
    "next": "^12.0.9",
    "next-pwa": "^5.4.4",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-share": "^4.4.0",
    "react-waypoint": "^10.1.0",
    "reveal.js": "^4.2.1"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^12.0.9",
    "@types/d3-force": "^3.0.3",
    "@types/gestalt": "^41.0.0",
    "@types/node": "^17.0.13",
    "@types/puppeteer": "^5.4.4",
    "@types/react": "^17.0.38",
    "@types/react-dom": "^17.0.11",
    "dependency-cruiser": "^11.3.0",
    "next-sitemap": "^2.0.7",
    "puppeteer": "^13.1.2",
    "serve": "^13.0.2",
    "typescript": "^4.5.5",
    "@bubblewrap/cli": "^1.15.0"
  },
  "comments": {
    "next-transpile-modules": "used for amCharts or any lib that needs next.config.js",
    "@types/lz-string": "^1.3.34",
    "lz-string": "^1.4.4"
  }
}
